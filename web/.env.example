# Reown / WalletConnect project ID. Register at https://cloud.reown.com.
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Protocol addresses on Base Sepolia. Fill these in after running
# `yarn workspace @streams/contracts deploy baseSepolia --tags deploy`.
NEXT_PUBLIC_STREAM_VAULTS_ADDRESS=
NEXT_PUBLIC_STREAM_VAULTS_CONFIG_ADDRESS=
NEXT_PUBLIC_SMART_ACCOUNT_REGISTRY_ADDRESS=

# SuperToken (USDCx) on Base Sepolia — needed for streaming and the Superfluid
# permissions gate. Look this up in the Superfluid Console for Base Sepolia.
NEXT_PUBLIC_USDCX_ADDRESS=

# Underlying tokens (canonical defaults are baked in; override only if needed).
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_WETH_ADDRESS=

# Superfluid CFAv1Forwarder canonical address. Override only on chains that
# don't expose it at 0xcfA132E353cB4E398080B9700609bb008eceB125.
NEXT_PUBLIC_CFA_FORWARDER_ADDRESS=
