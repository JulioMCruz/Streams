# Block explorer API (Basescan / Etherscan multichain)
ETHERSCAN_API_KEY=

# The Graph (Superfluid subgraph queries from bot)
THE_GRAPH_API_KEY=

# RPC endpoints
RPC_HTTPS_BASE_MAINNET=

# Uniswap Trading API (optional auth header). The bot calls the public endpoint
# and falls back to the unauthenticated path if not provided.
UNISWAP_API_BASE=
UNISWAP_API_KEY=

# Wallets
## Deployer — owner of StreamVaults / StreamVaultsConfig
WALLET_DEPLOYER_ADDRESS=
WALLET_DEPLOYER_PRIVATE_KEY=

## Bot — single global key authorized to call StreamVaults.executeSwap
WALLET_BOT_ADDRESS=
WALLET_BOT_PRIVATE_KEY=
