# Network
RPC_HTTPS_BASE_SEPOLIA=
# Optional: deployment folder under contracts/deployments/. Defaults to
# baseSepolia. Set to "localhost" when smoke-testing against `hardhat node`.
NETWORK_NAME=

# Bot identity (must match config.bot() on StreamVaultsConfig)
WALLET_BOT_PRIVATE_KEY=

# Loop cadence
POLL_INTERVAL_MS=30000
RUN_ONCE=

# Optional: override the from-block used to discover smart accounts.
# Plain integer (e.g. 12345678). Defaults to 0. Set it to your StreamVaults
# deployment block to speed scans and avoid the RPC getLogs range limit.
DISCOVERY_FROM_BLOCK=

# Uniswap Trading API (optional auth header). The bot calls the public endpoint
# and falls back to the unauthenticated path if not provided.
UNISWAP_API_BASE=https://trading-api-labs.interface.gateway.uniswap.org
UNISWAP_API_KEY=

# Strategy tokens. The bot downgrades the streamed SuperToken (USDCx) into its
# underlying (USDC) before swapping.
# REQUIRED: the USDCx SuperToken address on your network. There is no safe
# default — a wrong value makes the bot read a zero balance and never trade.
SUPER_TOKEN_USDCX=
# Optional: underlying token. Defaults to Base Sepolia USDC.
TOKEN_IN_USDC=

# Log level: debug | info | warn | error. Default info.
LOG_LEVEL=
